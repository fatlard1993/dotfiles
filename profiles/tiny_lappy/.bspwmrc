#!/bin/zsh
## $HOME/.config/bspwmrc

# ctrl/alt swap - was previously reapplied on every new shell (.zshrc), which
# is wasted work for something that's session-wide X state; once here at
# session start is enough.
[ -f "$HOME/.Xmodmap" ] && xmodmap "$HOME/.Xmodmap"

. "$HOME/.dotfiles/ubuntu/.bspwmrc"
