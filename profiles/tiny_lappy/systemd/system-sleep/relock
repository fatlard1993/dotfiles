#!/bin/bash
# slock (our fork, profiles/tiny_lappy/slock/) starts once via xss-lock
# before suspend and runs straight through resume. If autorandr
# reconfigures the monitor on resume (autorandr.service,
# WantedBy=sleep.target) while it's still up, its cached background no
# longer matches the new geometry - used to render as a blank/white lock
# screen with stock i3lock, which had no way to redraw itself.
#
# `system-lock recapture` re-shoots the screenshot/blur/badge base at the
# current resolution; slock polls screen_locked.png's mtime itself (see
# config.def.h) and picks up the refresh on its own. This is a separate
# short-lived invocation, not a relaunch of the slock that's been running
# since before suspend (suspend pauses processes, it doesn't kill them).
#
# Runs as root with no X session context - see ubuntu/.bspwmrc's
# DBUS_SESSION_BUS_ADDRESS/XDG_SESSION_TYPE comments for why.
#
# Per systemd-sleep(8), user.slice is frozen for the duration of these
# hooks, so this runs once the freeze lifts, right as resume completes -
# a better sync point than any delay we could construct manually.

[ "$1" = "post" ] || exit 0

su chase -c 'DISPLAY=:0 XAUTHORITY=/run/user/1000/gdm/Xauthority /home/chase/.dotfiles/ubuntu/bin/system-lock recapture'
