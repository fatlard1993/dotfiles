## htpc overlay - loaded alongside the shared base (ubuntu/.sxhkdrc, linked
## as ~/.config/sxhkd/sxhkdrc.common). Only chords that are
## machine-specific or bound differently per machine live here.

# Program Launcher (couch-habit chord, kept alongside the base's
# super+space)
ctrl + @space
	rofi -show drun -show-icons=true

# Physical power button: this is an appliance - a bare press shuts the box
# down, no menu, no confirm (reachable because the shared
# ubuntu/systemd/logind.conf sets HandlePowerKey=ignore, so the keypress
# lands here instead of logind acting on it). ctrl held = reboot (base).
XF86PowerOff
	$HOME/.dotfiles/ubuntu/bin/pc-leave shutdown

# Close and Kill (plain bspwm close here - the laptop's ctrl+w forwarding
# trick is for browser-tab-heavy use, not the couch)
super + {_,shift + }w
	bspc node -{c,k}

# Notes
super + n
	mousepad $HOME/.priv-config/profiles/personal/notes.md
