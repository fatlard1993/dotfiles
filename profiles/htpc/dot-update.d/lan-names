#!/bin/zsh

source "$HOME/.dotfiles/bin/lib/dot-util" "$0" "$@"

# Friendly names for everything this box serves: dnsmasq (already the
# house's DNS - see dnsmasq/dnsmasq.conf) answers *.home names, and caddy
# fans port 80 out to the right service by Host header. The one map below
# generates both halves so they can't drift. Minecraft needs no entry here -
# `htpc.home` works directly as the server address since it runs on the
# default port.
typeset -A services=(
	[htpc]=8033
	[humanity]=8032
	[void-driller]=1040
	[sorcery-and-savagery]=3040
	[games]=8034
	[land-ledger]=7450
	[remote]=8793
)
# htpc -> home-page (the landing server every machine runs); remote ->
# htpc-remote; games -> game-night. The four games also appear in
# dot-update.d/game-servers' loop - a new game needs both.

command -v caddy > /dev/null || {
	echo "Installing caddy"

	sudo env DEBIAN_FRONTEND=noninteractive apt install -y caddy
}

echo "Generating dnsmasq LAN names"

# The interface holding the default route is the LAN-facing one.
# interface-name resolves each name to that interface's *current* address,
# so nothing here hardcodes an IP that could go stale.
lanInterface=$(ip route show default | awk '{print $5; exit}')

if [[ -z $lanInterface ]]; then
	echo "No default route right now - skipping LAN name generation (a"
	echo "half-written drop-in would fail dnsmasq's config check and take"
	echo "down house DNS)"

	return
fi

{
	echo "# Generated by profiles/htpc/dot-update.d/lan-names - edits get overwritten"

	for name in ${(k)services}; do
		echo "interface-name=$name.home,$lanInterface"
	done
} | sudo tee /etc/dnsmasq.d/lan-names.conf > /dev/null

sudo systemctl restart dnsmasq

echo "Generating Caddyfile"

# The explicit http:// prefixes matter: without them caddy would auto-HTTPS
# these private names with certs from its internal CA, and every phone in
# the house would throw trust warnings. Plain HTTP on the LAN matches how
# these services are already reached by IP:port. WebSockets (the games'
# transport) proxy through reverse_proxy natively.
caddyfile=$(mktemp)

{
	echo "# Generated by profiles/htpc/dot-update.d/lan-names - edits get overwritten"

	for name in ${(k)services}; do
		echo ""
		echo "http://$name.home {"
		echo "	reverse_proxy localhost:$services[$name]"
		echo "}"
	done
} > $caddyfile

# refuse to install a broken proxy config over a working one
if caddy validate --config $caddyfile --adapter caddyfile > /dev/null 2>&1; then
	sudo cp $caddyfile /etc/caddy/Caddyfile
	sudo systemctl reload-or-restart caddy
else
	echo "Generated Caddyfile failed validation - keeping the existing one:"
	caddy validate --config $caddyfile --adapter caddyfile

	rm -f $caddyfile
	return 1
fi

rm -f $caddyfile
