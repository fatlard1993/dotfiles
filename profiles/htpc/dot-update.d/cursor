#!/bin/zsh

source "$HOME/.dotfiles/bin/lib/dot-util" "$0" "$@"

# The shared gtk hook (run via 0_ubuntu, which sorts before this file) sets
# cursor-size 32, tuned for the laptop panel - on the 4K TV that renders a
# cursor small enough to lose, most painfully in Sims 4 under Proton (the
# game has UI scaling but no cursor scaling of its own). The chain that
# makes this one dconf key fix the *game*: ubuntu/.bspwmrc exports
# XCURSOR_SIZE from this key at session start, startup.d/steam-bigpicture
# launches Steam from that same shell, and Proton's cursor tracks
# XCURSOR_SIZE (the standard ProtonDB fix for this title, values 24-96).
#
# Takes effect at next login - the export is read once by .bspwmrc, and
# Steam/games only inherit env at launch.
echo "Setting TV cursor size"

dconf write /org/gnome/desktop/interface/cursor-size "64"

# XCURSOR_SIZE handles every X-side cursor, but the Sims 4 draws its
# in-game cursor Windows-side and Wine ignores the X size for it (tested:
# env verified inside the game's process, cursor still tiny). Dead ends,
# so nobody retries them: cursor mods only reskin (the game caps cursor
# resources at 32x32); prefix DPI (LogPixels 192) does reach the game but
# backwards - the game reads it and shrinks its whole UI (useosdpi below)
# while Wine never scales the cursor, and every session rewrites the key
# back to 96 on exit anyway. What works is gamescope (launch options
# below): the game renders native 4K, gamescope composites the cursor
# itself and scales it 2x.
simsIni="$HOME/.steam/steam/steamapps/compatdata/1222670/pfx/drive_c/users/steamuser/Documents/Electronic Arts/The Sims 4/Options.ini"

# useosdpi = 1 ships by default and makes the game resize itself from the
# prefix DPI (badly - same class of bug as Sims 4 on Windows >100%
# scaling). Off is pure hardening now that LogPixels stays 96. The game
# rewrites Options.ini on exit (discarding live edits), so skip while the
# prefix's wineserver is up. The file is CRLF - patterns match and
# re-emit the \r so the game's parser stays happy.
if [[ -f $simsIni ]] && grep -q $'^useosdpi = 1\r' $simsIni; then
	if pgrep -f wineserver > /dev/null; then
		echo "Sims 4 prefix is live - skipping useosdpi (rerun dot-update with the game closed)"
	else
		echo "Disabling Sims 4 OS-DPI tracking"

		# The useosdpi era also saved a DPI-mangled window size (2023x1138
		# on the 4K TV) - repair it in the same pass, then never touch
		# resolution again once useosdpi is 0.
		sed -i -e $'s/^useosdpi = .*/useosdpi = 0\r/' \
			-e $'s/^resolutionwidth = .*/resolutionwidth = 3840\r/' \
			-e $'s/^resolutionheight = .*/resolutionheight = 2160\r/' $simsIni
	fi
fi

# The actual cursor fix: gamescope wraps the game, rendering at native 4K
# (-w/-h) while compositing the cursor itself at 2x (--cursor-scale-height
# 1080 against the 2160 output). --force-grab-cursor is load-bearing -
# without it nested gamescope forwards the host cursor unscaled and the
# scale flag never engages. PATH prefix because Debian ships
# gamescopereaper in /usr/games, which the greetd session PATH lacks (same
# trap as steam itself, see startup.d/steam-bigpicture). Steam holds
# localconfig.vdf in memory and rewrites it on exit, so only touched while
# steam is down.
simsLaunchOptions='PATH=/usr/games:$PATH gamescope -w 3840 -h 2160 -f --cursor-scale-height 1080 --force-grab-cursor -- %command%'
steamCfg="$HOME/.steam/debian-installation/userdata/71499228/config/localconfig.vdf"

if [[ -f $steamCfg ]] && ! grep -qF "$simsLaunchOptions" $steamCfg; then
	if pgrep -x steam > /dev/null; then
		echo "Steam is live - skipping Sims 4 launch options (rerun dot-update with steam closed)"
	else
		echo "Setting Sims 4 gamescope launch options (cursor scale)"

		python3 - "$steamCfg" "$simsLaunchOptions" <<'EOF'
import sys

path, lo = sys.argv[1], sys.argv[2]
s = open(path, encoding='utf-8', errors='surrogateescape').read()

# The eula key is the stable landmark inside the Sims 4 app block.
anchor = s.find('"1222670_eula_0"')
if anchor == -1:
    sys.exit('sims 4 app block not found in localconfig.vdf')

line = '\t\t\t\t\t\t"LaunchOptions"\t\t"' + lo + '"\n'
block = s[max(0, anchor - 400):anchor]

if '"LaunchOptions"' in block:
    start = max(0, anchor - 400) + block.rindex('"LaunchOptions"')
    end = s.index('\n', start) + 1
    start = s.rindex('\n', 0, start) + 1
    s = s[:start] + line + s[end:]
else:
    start = s.rindex('\n', 0, anchor) + 1
    s = s[:start] + line + s[start:]

open(path, 'w', encoding='utf-8', errors='surrogateescape').write(s)
EOF
	fi
fi
