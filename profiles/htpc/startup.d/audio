#!/bin/zsh

# Route everything through the combine sink (HDMI receiver + headphone-jack
# house zones - see pipewire/combine-sink.conf) by default. Backgrounded
# with a readiness wait since pipewire comes up in parallel via systemd
# --user; re-asserted every login since dual-output is how this machine
# is meant to run.
#
# First-boot, hardware-specific: for real surround, the HDMI card profile
# must be a surround one - `pactl list cards` to check, `pactl
# set-card-profile <card> output:hdmi-surround-extra1` to set (wireplumber
# remembers it). Volume keys move both outputs together; per-zone level
# lives on the amps themselves.
{
	for _ in {1..20}; do
		pactl info > /dev/null 2>&1 && break
		sleep 0.5
	done

	pactl set-default-sink combine_sink
} > /dev/null 2>&1 &
