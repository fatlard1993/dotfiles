#!/bin/zsh

source "$HOME/.dotfiles/bin/lib/dot-util" "$0"
# ctx-api — public API surface of a module: exported symbols with signatures and descriptions
# Shows existing JSDoc for documented exports, generates descriptions for undocumented ones
# Usage: ctx-api <file>

setopt errexit pipefail

file="${1:?usage: ctx-api <file>}"
[[ -f "$file" ]] || { logError "not found: $file"; exit 1; }

echo "## API: $file"
echo ""

# Show structure
ctx-file "$file"

echo ""
echo "## Descriptions"
echo ""

# Generate descriptions for undocumented exports
ctx-jsdoc "$file" 2>/dev/null | grep -v "^//" | grep -v "^$" || true
