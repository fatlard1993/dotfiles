#!/usr/bin/env python3
import sys
import re

lines = sys.stdin.read().split('\n')

if lines and lines[-1] == '':
    lines.pop()

non_empty = [l for l in lines if l.strip()]
min_indent = min((len(l) - len(l.lstrip()) for l in non_empty), default=0)

stripped = [l[min_indent:] if len(l) >= min_indent else l.lstrip() for l in lines]

BLOCK_START = re.compile(r'^(\s*[-*+]|\s*\d+[.)]\s|\s*#{1,6}\s|>\s*|```)')

out = []
i = 0
while i < len(stripped):
    line = stripped[i]

    if not line.strip():
        out.append('')
        i += 1
        continue

    if BLOCK_START.match(line):
        out.append(line)
        i += 1
        continue

    para = line.rstrip()
    while i + 1 < len(stripped):
        nxt = stripped[i + 1]
        if not nxt.strip() or BLOCK_START.match(nxt):
            break
        para += ' ' + nxt.strip()
        i += 1
    out.append(para)
    i += 1

while out and not out[-1].strip():
    out.pop()

print('\n'.join(out))
