#!/usr/bin/env bash
# Claude Code status line.
# Receives session JSON on stdin; outputs ANSI-colored status bar content.

set -euo pipefail

json=$(cat)

# Parse fields
project_dir=$(printf '%s' "$json" | jq -r '.workspace.project_dir // .cwd // env.PWD')
model=$(printf '%s' "$json" | jq -r '.model.display_name // ""')
session_name=$(printf '%s' "$json" | jq -r '.session_name // ""')
agent_name=$(printf '%s' "$json" | jq -r '.agent.name // ""')
worktree=$(printf '%s' "$json" | jq -r '.workspace.git_worktree // ""')
ctx_remaining=$(printf '%s' "$json" | jq -r 'if .context_window.remaining_percentage != null then .context_window.remaining_percentage else "" end')
rate_limit=$(printf '%s' "$json" | jq -r '.rate_limits.five_hour.used_percentage // ""')

# Hue color from project_dir — matches kitty-bg window tint
hash=$(printf '%s' "${project_dir:-$HOME}" | cksum | awk '{print $1}')
idx=$(( hash % 24 ))

IFS=' ' read -r r g b <<< "$(awk -v idx="$idx" -v s="0.80" -v l="0.60" 'BEGIN {
  h = idx * 15
  a = 2*l - 1; if (a < 0) a = -a
  c = (1 - a) * s
  hp = h / 60
  hp2 = hp - int(hp / 2) * 2
  d = hp2 - 1; if (d < 0) d = -d
  x = c * (1 - d)
  m = l - c / 2
  if      (hp < 1) { r1=c; g1=x; b1=0 }
  else if (hp < 2) { r1=x; g1=c; b1=0 }
  else if (hp < 3) { r1=0; g1=c; b1=x }
  else if (hp < 4) { r1=0; g1=x; b1=c }
  else if (hp < 5) { r1=x; g1=0; b1=c }
  else             { r1=c; g1=0; b1=x }
  printf "%d %d %d\n",
    int((r1+m)*255+0.5), int((g1+m)*255+0.5), int((b1+m)*255+0.5)
}')"

# Location label
if [[ -n "$session_name" ]]; then
  label="$session_name"
else
  folder=$(basename "${project_dir:-$HOME}")
  branch=$(git -C "${project_dir:-.}" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
  label="${folder}${branch:+ ($branch)}"
fi

[[ -n "$worktree" ]] && label="${label} ⎇${worktree}"
[[ -n "$agent_name" ]] && label="${label} [$agent_name]"

# Helpers
dim='\e[38;2;70;70;70m'
reset='\e[0m'
sep=" ${dim}·${reset} "

# ── Location (accent color)
printf '\e[38;2;%d;%d;%dm%s\e[0m' "$r" "$g" "$b" "$label"

# ── Model
[[ -n "$model" ]] && printf "${sep}\e[38;2;110;110;110m%s${reset}" "$model"

# ── Context remaining — red→yellow→green as space opens up
if [[ -n "$ctx_remaining" ]]; then
  if awk "BEGIN{exit !($ctx_remaining <= 20)}"; then
    ctx_color='\e[38;2;255;80;80m'
  elif awk "BEGIN{exit !($ctx_remaining <= 50)}"; then
    ctx_color='\e[38;2;255;180;50m'
  else
    ctx_color='\e[38;2;80;160;80m'
  fi
  printf "${sep}${ctx_color}%.0f%% left${reset}" "$ctx_remaining"
fi

# ── Rate limit (only when present and non-trivial)
if [[ -n "$rate_limit" ]] && awk "BEGIN{exit !($rate_limit > 10)}"; then
  if awk "BEGIN{exit !($rate_limit >= 80)}"; then
    rl_color='\e[38;2;255;80;80m'
  elif awk "BEGIN{exit !($rate_limit >= 50)}"; then
    rl_color='\e[38;2;255;180;50m'
  else
    rl_color='\e[38;2;150;150;150m'
  fi
  printf "${sep}${rl_color}%.0f%% limit${reset}" "$rate_limit"
fi
