#!/bin/zsh

[[ -o interactive ]] || return
[[ -n "$CLAUDECODE" ]] && return

_prompt_newline=$'\n'
_prompt_directory="%F{blue}[%~]%f"
_prompt_time="[%*]"
if [[ "$(uname -s)" == "Darwin" ]]; then
  _prompt_ip="%F{12}[$(ipconfig getifaddr en0)]%f"
else
  _prompt_ip="%F{12}[$(ip route get 1.1.1.1 2>/dev/null | awk '{print $7; exit}')]%f"
fi

git-prompt-commit() {
  git status --porcelain

  echo "â”Ł Enter a message to commit these changes"
  read "message?â”— "

echo -e '\e[1Aâ”Ł'

  git add .
  git commit -m "$message"
}

git-prompt-changes() {
  git status --porcelain

  local RED="\033[1;31m"
  local YELLOW="\033[1;33m"
  local GREEN="\033[1;32m"
  local NC="\033[0m"

  echo "â”Ł [${GREEN}1${NC}]: Commit, [${YELLOW}2${NC}]: Stash, [${RED}3${NC}]: Clear"
  read "action?â”— "

  echo -e '\e[1Aâ”Ł'

  if [ "$action" = "1" ]; then
    git-prompt-commit
  elif [ "$action" = "2" ]; then
    git stash
  elif [ "$action" = "3" ]; then
    git-nah
  fi
}

git-prompt-push() {
  git cherry -v

  local RED="\033[1;31m"
  local YELLOW="\033[1;33m"
  local GREEN="\033[1;32m"
  local NC="\033[0m"

  echo "â”Ł [${GREEN}1${NC}]: Push, [${YELLOW}2${NC}]: Force Push, [${RED}3${NC}]: Uncommit"
  read "action?â”— "

  echo -e '\e[1Aâ”Ł'

  if [ "$action" = "1" ]; then
    git push
  elif [ "$action" = "2" ]; then
    git push --force
  elif [ "$action" = "3" ]; then
    git reset --mixed "HEAD~$(git cherry -v | wc -l | xargs)"
  fi
}

git-prompt-rebase() {
  echo "â”Ł Abort the in-progress rebase?"
  read REPLY\?"â”— [Return] to continue - [Ctrl + c] to cancel"

  echo -e '\e[1Aâ”Ł'

  git rebase --abort
}

gitm() {
  local isInGitRepo=$([ -d .git ] && echo true || git rev-parse --git-dir >/dev/null 2>&1)

  [[ $isInGitRepo ]] && {
    local hasGitChanges=$(git status --porcelain)
    local gitRoot=$(git rev-parse --show-toplevel 2 &>/dev/null)
    local hasUnpushedCommits=$(git cherry -v)
    local isMidRebase=""

    [ -d "$gitRoot/.git/rebase-apply" ] && isMidRebase=true
    [ -d "$gitRoot/.git/rebase-merge" ] && isMidRebase=true

    [[ "$hasGitChanges" = "" ]] || BUFFER="git-prompt-changes"
    [[ $hasUnpushedCommits ]] && BUFFER="git-prompt-push"
    [[ $isMidRebase ]] && BUFFER="git-prompt-rebase"
  }
}


# â”€â”€ async git branch display â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

typeset -A _prompt_git_cache     # pwd -> rendered git line
typeset -A _prompt_git_unpushed  # pwd -> "1" if unpushed commits exist
typeset -A _prompt_git_rebasing  # pwd -> "1" if mid-rebase
_prompt_async_pid=""
_prompt_async_gen=0

_prompt_gitBranch() {
  echo "${_prompt_git_cache[$PWD]}"
}

_prompt_gitBranch_compute() {
  local dir="$1"
  local tmpbase="${2:-}"
  cd "$dir" 2>/dev/null || return

  { [ -d .git ] || git rev-parse --git-dir > /dev/null 2>&1; } || return

  # Kick off the two slow operations in parallel
  local _ptmp
  _ptmp=$(mktemp -d)
  git status --porcelain > "$_ptmp/ch" 2>/dev/null &
  git rev-list --count --left-right @{upstream}...HEAD > "$_ptmp/up" 2>/dev/null &

  # Fast sequential calls run while the parallel ones complete
  local gitBranch gitRoot gitCommit
  gitBranch=$(git rev-parse --abbrev-ref HEAD)
  gitBranch=${gitBranch//\%/%%}  # escape '%'
  [[ "$gitBranch" =~ ".*no branch.*" ]] && gitBranch="%F{red}$gitBranch%f"
  gitRoot=$(git rev-parse --show-toplevel 2>/dev/null)
  gitCommit=$(git rev-parse --short HEAD)

  local isMidRebase=""
  local jsRuntime=""

  [ -d "$gitRoot/.git/rebase-apply" ] && isMidRebase=true
  [ -d "$gitRoot/.git/rebase-merge" ] && isMidRebase=true


  [[ -f "$gitRoot/package.json" ]] && {
    if [[ -f "$gitRoot/bunfig.toml" ]]; then
      jsRuntime="%F{magenta}[$(bun --version)]%f"
    else
      jsRuntime="%F{magenta}[$(node --version)]%f"
    fi
  }

  # Collect parallel results
  wait
  local hasGitChanges rawup gitAhead gitBehind hasUnpushedCommits
  hasGitChanges=$(cat "$_ptmp/ch")
  rawup=$(cat "$_ptmp/up")
  gitAhead=0; gitBehind=0
  if [[ -n "$rawup" ]]; then
    gitBehind=${rawup%%$'\t'*}
    gitAhead=${rawup##*$'\t'}
  fi
  (( gitAhead > 0 )) && hasUnpushedCommits="1" || hasUnpushedCommits=""
  command rm -rf "$_ptmp"

  local gitStatusColor="green"
  [[ $hasGitChanges ]] && gitStatusColor="yellow"
  [[ $hasUnpushedCommits ]] && gitStatusColor="magenta"
  [[ $isMidRebase ]] && gitStatusColor="red"

  local aheadBehind=""
  (( gitAhead > 0 )) && aheadBehind+="%F{magenta}+${gitAhead}%f"
  (( gitBehind > 0 )) && aheadBehind+="%F{red}-${gitBehind}%f"

  local gitIcon="%F{${gitStatusColor}}îśĄ%f "
  local branch="%F{cyan}[$gitBranch%F{cyan}${aheadBehind}]%f"
  local commit="%F{cyan}[$gitCommit]%f"
  local packageVersion=""
  [[ -f "$gitRoot/package.json" ]] && packageVersion="%F{cyan}[$(jq -r .version "$gitRoot/package.json" 2>/dev/null)]%f"

  [[ -n "$tmpbase" ]] && printf '%s\n%s\n' "${hasUnpushedCommits:+1}" "${isMidRebase:+1}" > "${tmpbase}.state"

  echo "${_prompt_newline}â”Ł ${gitIcon}${branch}${commit}${packageVersion}${jsRuntime}"
}

_prompt_start_async() {
  [[ -n "$_prompt_async_pid" ]] && kill "$_prompt_async_pid" 2>/dev/null
  (( _prompt_async_gen++ ))

  local target_pwd="$PWD"
  local gen="$_prompt_async_gen"
  local tmpbase="/tmp/_zsh_prompt_${$}"

  {
    local result
    result=$(_prompt_gitBranch_compute "$target_pwd" "$tmpbase")
    printf '%s\n%s\n' "$gen" "$target_pwd" > "${tmpbase}.key"
    printf '%s' "$result" > "${tmpbase}.result"
    kill -USR1 $$ 2>/dev/null
  } &!

  _prompt_async_pid=$!
}

TRAPUSR1() {
  local tmpbase="/tmp/_zsh_prompt_${$}"
  [[ -f "${tmpbase}.key" ]] || return

  local gen target_pwd
  {
    IFS= read -r gen
    IFS= read -r target_pwd
  } < "${tmpbase}.key"

  [[ "$gen" -eq "$_prompt_async_gen" ]] || return

  local result
  result=$(cat "${tmpbase}.result" 2>/dev/null)

  local _su="" _sr=""
  [[ -f "${tmpbase}.state" ]] && { IFS= read -r _su; IFS= read -r _sr; } < "${tmpbase}.state"
  command rm -f "${tmpbase}.key" "${tmpbase}.result" "${tmpbase}.state"

  [[ "${_prompt_git_cache[$target_pwd]}" == "$result" ]] && return

  _prompt_git_cache[$target_pwd]="$result"
  _prompt_git_unpushed[$target_pwd]="$_su"
  _prompt_git_rebasing[$target_pwd]="$_sr"
  zle && { zle reset-prompt; zle -R }
}

