_prompt_user() {
  local user="%F{green}[%n]%f"
  local host="%F{magenta}[%m]%f"

  [[ $SSH_TTY ]] && echo "${user}${host}"
}

_prompt_lastCommand() {
  local lastCommandSeconds=${_elapsed[-1]}
  local lastCommandExit="%F{red}%(?..%B  %?%b)%f"
  local lastCommand="$lastCommandExit [$lcmd]"

  [[ "$lcmd" = "" ]] && lastCommand=""

  if [[ "$lastCommandSeconds" = "" ]]; then
    echo ""
  elif (( $lastCommandSeconds > 3600 )); then
    local lastCommandHours=$(gdate -d@${lastCommandSeconds} -u +%H:%M:%S)
    echo "â”—${lastCommand}[${lastCommandHours}]"
  elif (( $lastCommandSeconds > 60 )); then
    local lastCommandMinutes=$(gdate -d@${lastCommandSeconds} -u +%M:%S)
    echo "â”—${lastCommand}[${lastCommandMinutes}]"
  else
    echo "â”—${lastCommand}[${lastCommandSeconds}s]"
  fi
}

preexec () {
  if [ "$cmd" ]; then
    (( $#_elapsed > 100 )) && set -A _elapsed $_elapsed[-100,-1]
    typeset -ig _start=SECONDS
  fi
}

precmd () {
  printf '\r'

  lcmd=$cmd

  (( _start >= 0 )) && set -A _elapsed $_elapsed $(( SECONDS-_start ))
  _start=-1

  cmd=

  # Block on first visit to a directory so the prompt renders with data
  if (( ! ${+_prompt_git_cache[$PWD]} )); then
    local _stmp="/tmp/_zsh_prompt_sync_$$"
    _prompt_git_cache[$PWD]=$(_prompt_gitBranch_compute "$PWD" "$_stmp")
    local _su="" _sr=""
    [[ -f "${_stmp}.state" ]] && { IFS= read -r _su; IFS= read -r _sr; } < "${_stmp}.state"
    _prompt_git_unpushed[$PWD]="$_su"
    _prompt_git_rebasing[$PWD]="$_sr"
    command rm -f "${_stmp}.state"
  fi

  _prompt_start_async
}

_prompt_commandPipe() {
  if [ "$cmd" ]; then
    echo "â”Ł "
  else
    echo "â”— "
  fi
}

_prompt_redraw() {
  zle reset-prompt
}

reset-prompt-and-accept-line() {
  [[ $BUFFER ]] || {
    BUFFER="cdm"

    [[ ${+_prompt_git_cache[$PWD]} -eq 1 && -n "${_prompt_git_cache[$PWD]}" ]] && {
      [[ -n "${_prompt_git_unpushed[$PWD]}" ]] && BUFFER="git-prompt-push"
      [[ -n "${_prompt_git_rebasing[$PWD]}" ]] && BUFFER="git-prompt-rebase"
    }
  }

  cmd=$BUFFER

  _prompt_redraw

  [[ $BUFFER ]] && zle .accept-line
}

zle -N accept-line reset-prompt-and-accept-line

setopt prompt_subst

trap _prompt_redraw WINCH

_prompt_line0='$(_prompt_lastCommand)'
_prompt_line1='${_prompt_newline}${_prompt_newline}â”Ź${_prompt_time}${_prompt_ip}${tty}$(_prompt_user)${_prompt_directory}'
_prompt_line2='$(_prompt_gitBranch)'
_prompt_line3='${_prompt_newline}$(_prompt_commandPipe)%# '

PROMPT="${_prompt_line0}${_prompt_line1}${_prompt_line2}${_prompt_line3}"
