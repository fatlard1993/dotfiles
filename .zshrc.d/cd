#!/bin/zsh

cd() {
	if [[ "$@" =~ "^\.{3,}$" ]]; then
		builtin cd $(echo "$@" | cut -c2- | sed -e 's/\./\.\.\//g')
	elif [[ "$@" == "." ]]; then
		# Go to real dir (i.e. if current dir is linked)
		builtin cd $(readlink -f .)
	elif [[ "$@" == "...git" ]]; then
		builtin cd $(git rev-parse --show-toplevel)
	elif [[ "$@" == "...m" ]]; then
		# cd MAGIC — frecent dirs first, then curated globs, deduplicated
		local selected
		selected=$(
			{
				command zoxide query -l 2>/dev/null
				print -l \
					~/Projects/*(N/e:'[[ -d $REPLY/.git ]]':) \
					~/Projects/*/*(N/e:'[[ -d $REPLY/.git ]]':) \
					$ITENTIAL_FOLDER/*/(iap|iag)(N/) \
					$ITENTIAL_FOLDER/release/*/*/(iap|iag)(N/) \
					$ITENTIAL_FOLDER/*/iap/services/*(N/) \
					$ITENTIAL_FOLDER/*/iap/dev/services/*(N/) \
					$ITENTIAL_FOLDER/release/*/*/iap/services/*(N/) \
					$ITENTIAL_FOLDER/release/*/*/iap/dev/services/*(N/) \
					~/*(N/) \
					../*(N/) \
					./*(N/) \
					./*/*(N/e:'[[ -d $REPLY/.git ]]':)
			} | awk '!seen[$0]++' | fzf \
				--bind 'tab:reload(command ls -1d "{}"/*/  2>/dev/null | command sed "s|/$||")+clear-query' \
				--bind 'shift-tab:reload(command ls -1d "$(dirname "{}")"/*/ 2>/dev/null | command sed "s|/$||")+clear-query'
		)
		if [[ -n "$selected" ]]; then
			builtin cd "$selected"
			command zoxide add "$PWD" 2>/dev/null
		fi
	else
		builtin cd "$@"
	fi
}

alias cd-="cd -"
alias cd.='cd .'
alias cdm='cd ...m'
