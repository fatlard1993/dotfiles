#!/bin/zsh

fpath=($dotfilesPath/zshcompletion $fpath)

# fpath=($binPath/completion $fpath)

# Enable completions — single call with a fixed dump path.
# Guard prevents re-init if something else already called compinit this session.
autoload -Uz compinit
(( ${+functions[compdef]} )) || compinit -d "$HOME/.zcompdump"