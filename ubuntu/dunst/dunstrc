; Tomorrow Night base16 palette, shared with kitty/rofi/polybar (see
; kitty.conf.d/theme.conf, ubuntu/rofi/theme.rasi, ubuntu/polybar/config.ini)

[global]
	monitor = 0
	follow = mouse

	origin = top-right
	offset = (10, 40)
	width = 320
	height = (0, 200)

	corner_radius = 0
	frame_width = 2
	frame_color = "#f0c674"
	separator_color = frame
	separator_height = 2

	padding = 10
	horizontal_padding = 10

	font = "Hack Nerd Font Mono 11"
	markup = full
	format = "<b>%s</b>\n%b"
	word_wrap = yes
	alignment = left
	vertical_alignment = center

	sort = yes
	indicate_hidden = yes
	stack_duplicates = true
	hide_duplicate_count = false
	show_age_threshold = 60
	sticky_history = yes
	history_length = 20
	show_indicators = yes
	ignore_newline = no
	idle_threshold = 120

	progress_bar = true
	progress_bar_height = 10
	progress_bar_frame_width = 1
	progress_bar_corner_radius = 0
	icon_corner_radius = 0

	dmenu = /usr/bin/rofi -dmenu -p dunst:

[urgency_low]
	background = "#000000"
	foreground = "#969896"
	frame_color = "#373b41"
	highlight = "#373b41"
	timeout = 6

[urgency_normal]
	background = "#000000"
	foreground = "#e0e0e0"
	frame_color = "#f0c674"
	highlight = "#f0c674"
	timeout = 6

[urgency_critical]
	background = "#000000"
	foreground = "#e0e0e0"
	frame_color = "#cc6666"
	highlight = "#cc6666"
	timeout = 0

; rapid-fire hotkey feedback (brightness/volume) should clear itself quickly
; instead of lingering like a normal notification
[osd_brightness]
	summary = "Screen Brightness"
	timeout = 1.5

[osd_kbd_backlight]
	summary = "Keyboard Backlight"
	timeout = 1.5

[osd_volume]
	summary = "Volume"
	timeout = 1.5
