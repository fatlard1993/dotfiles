#!/bin/zsh

# X's own screensaver blanking defaults to the same 600s timeout as
# xautolock's idle lock (see ubuntu/startup.d/screenlock) - when both fire
# together, the blank races system-lock's scrot and it captures a blank
# screen instead of the desktop. We already have our own idle handling, so
# X's built-in blanking is redundant as well as the actual cause here.
xset s off

xrdb -merge ~/.Xresources

xsetroot -cursor_name left_ptr &

# picom refuses a second instance on its own ("Another composite manager is
# already running"), but guard it anyway to skip the spawn+immediate-exit.
pgrep -x picom > /dev/null || picom &