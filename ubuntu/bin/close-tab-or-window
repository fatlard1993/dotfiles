#!/bin/bash
# Usage: close-tab-or-window
#
# Forwards ctrl+w to the focused window - closes the current tab in
# Chrome/Firefox/most editors, unlike bspc node -c, which closes the whole
# X11 window (all tabs at once). No fallback: super+shift+w (bspc node -k)
# is the hard-close.
#
# kitty exception: it doesn't bind ctrl+w (shell word-delete), and its
# native ctrl+shift+w doesn't survive this machine's ctrl<->alt keycode
# swap (xdotool injects a spurious Alt, kitty sees ctrl+alt+shift+w and
# ignores it). One kitty OS window is one shell here, so bspc node -c is
# already tab-granular for it and stays polite (real WM delete request).
#
# Matched by _NET_WM_PID -> comm, not WM_CLASS: WM_CLASS is whatever
# --class was passed at spawn (e.g. quakeTerm - see
# ubuntu/bin/terminal-smart), so a class list would go stale with every
# new custom class. No _NET_WM_PID falls through to the ctrl+w forward,
# the right default.
#
# No --window flag: xdotool would use XSendEvent, which Chrome discards as
# synthetic. Plain xdotool key uses XTestFakeKeyEvent (indistinguishable
# from a real keypress) on whatever holds focus.

pid=$(xprop -id "$(xdotool getactivewindow)" _NET_WM_PID 2>/dev/null | grep -oE '[0-9]+$')

if [ -n "$pid" ] && [ "$(ps -o comm= -p "$pid" 2>/dev/null)" = "kitty" ]; then
	bspc node -c
else
	# forward-key, not bare xdotool - it repairs the stuck-modifier race
	# --clearmodifiers has when super is released mid-forward.
	"$HOME/.dotfiles/ubuntu/bin/forward-key" ctrl+w
fi
