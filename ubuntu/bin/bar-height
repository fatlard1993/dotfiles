#!/bin/bash
# Usage: bar-height <monitor>
# Prints "<dpi> <height>" for the given monitor's polybar - the single
# source of truth for bar sizing, used by startup.d/status-bar to launch
# the bars and by bin/rofi to sit flush underneath them.
#
# eDP-1 stays hardcoded at dpi=192/height=35 - its true physical DPI
# measures ~248 and visibly overshoots when used directly, likely because
# of the separate 2x GTK scaling (dot-update.d/gtk) layered on top. Every
# other monitor uses its own true physical DPI directly (confirmed by
# trial) - scaling *relative* to eDP-1's ratio undershot badly instead,
# since an external display sits farther from the eyes than a laptop panel.

mon=$1
dpi=192
height=35

if [ -n "$mon" ] && [ "$mon" != "eDP-1" ]; then
	line=$(xrandr --query | grep "^${mon} connected")
	px=$(grep -oP '\d+x\d+\+' <<<"$line" | head -1 | grep -oP '^\d+')
	mm=$(grep -oP '\d+mm x \d+mm' <<<"$line" | grep -oP '^\d+')
	if [[ -n "$px" && -n "$mm" && "$mm" -gt 0 ]]; then
		mon_dpi=$((px * 254 / mm / 10))
		if [ "$mon_dpi" -gt 0 ]; then
			dpi=$mon_dpi
			height=$((35 * dpi / 192))
		fi
	fi
fi

# True physical DPI assumes desk viewing distance; a TV is meters away, so
# the same math renders a couch-invisible bar (htpc's 32" 4K measures 137
# DPI -> a 24px bar on 2160 lines). A profile can ship a .bar-scale
# multiplier on top of the EDID-derived base - viewing distance
# correction, not a per-monitor hardcode.
scaleFile="$HOME/.dotfiles/profiles/$(cat "$HOME/.dotfilesProfile" 2>/dev/null)/.bar-scale"
if [ -f "$scaleFile" ]; then
	scale=$(cat "$scaleFile")
	dpi=$((dpi * scale))
	height=$((height * scale))
fi

echo "$dpi $height"
