#!/bin/bash
# Usage: forward-key <xdotool keystroke spec, e.g. ctrl+c>
#
# `xdotool key --clearmodifiers` with a real modifier held: read held
# modifiers, release them synthetically, inject the keystroke, re-press
# what was cleared. sxhkd bindings using this fire on @release - while
# fingers are lifting - so the physical release often lands mid-dance: X
# consumes the real release, xdotool re-presses synthetically, and the
# modifier is now logically held with no physical key down. No release
# event is coming, so every click becomes a modifier-click until tapped
# again.
#
# The repair re-syncs logical state to physical truth: any modifier
# keysym with no keycode down on the real keyboard gets a synthetic keyup
# (a no-op on an already-released key, so unaffected modifiers cost
# nothing); a modifier still physically held is left alone.

xdotool key --clearmodifiers "$1"

# Physical slave keyboards only - the XTEST virtual device is excluded
# deliberately, because the stuck synthetic press lives *there*; including
# it would make the stuck modifier look legitimately held.
down=$(
	xinput list --short | awk -F'id=' '/slave +keyboard/ && !/XTEST/ {print $2+0}' |
		while read -r id; do
			xinput query-state "$id" 2>/dev/null
		done | grep -oP 'key\[\K[0-9]+(?=\]=down)' | sort -u
)

# xmodmap, not hardcoded keycodes: this machine swaps ctrl<->alt at the
# keycode level (see close-tab-or-window), so keysym->keycode has to be
# looked up, and several keysyms own two keycodes each here.
modmap=$(xmodmap -pke)

stuck=()

for sym in Super_L Super_R Control_L Control_R Alt_L Alt_R Shift_L Shift_R; do
	held=

	for code in $(awk -v s="$sym" '$4 == s {print $2}' <<< "$modmap"); do
		grep -qx "$code" <<< "$down" && { held=1; break; }
	done

	[ -z "$held" ] && stuck+=("$sym")
done

[ ${#stuck[@]} -gt 0 ] && xdotool keyup "${stuck[@]}"

exit 0
