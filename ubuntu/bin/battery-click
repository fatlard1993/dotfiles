#!/bin/bash
# Left-click handler for polybar's battery module. Polybar has no
# per-modifier click actions (click-left is a single fixed command), so
# whether Shift is held at click time is checked directly against the X
# server's pointer state instead - same approach as brightness-click.
# Plain click opens the battery menu (matching right-click); shift+click
# toggles the power-saver profile.

mask=$(python3 -c "
from Xlib import display
print(display.Display().screen().root.query_pointer()._data['mask'])
")

shift_mask=1

if ((mask & shift_mask)); then
	current=$(powerprofilesctl get)
	if [ "$current" = "power-saver" ]; then
		powerprofilesctl set balanced
		notify-send "Power profile" "balanced"
	else
		powerprofilesctl set power-saver
		notify-send "Power profile" "power-saver"
	fi
else
	$HOME/.dotfiles/ubuntu/bin/polybar-menu battery &
fi
