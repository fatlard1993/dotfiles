#!/bin/zsh

bspc monitor eDP-1 -d 1 2 3 4 5 6 7 8 9

# Any monitor other than the laptop panel gets its own dedicated desktop pool,
# whether it's connected at startup or plugged in later.
assign_secondary_desktops() {
	[[ "$1" == "eDP-1" ]] && return

	bspc monitor "$1" -d F1 F2 F3 F4 F5 F6 F7 F8 F9 F10 F11 F12
}

for monitor in $(bspc query -M --names); do
	assign_secondary_desktops "$monitor"
done

bspc subscribe monitor_add | while read -r _ _ monitor _; do
	assign_secondary_desktops "$monitor"
done &

bspc config border_width         2
bspc config window_gap          12

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config click_to_focus       true

bspc rule -a Gimp state=floating follow=on

for file in $HOME/.dotfiles/ubuntu/startup.d/*; . "$file"