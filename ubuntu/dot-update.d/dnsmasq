#!/bin/zsh

# Installs its own package (like the greetd hook) instead of trusting the
# aptfile: packages install via the *profile's* 1_apt, which sorts after
# the whole ubuntu chain - so on a never-bootstrapped machine this hook
# always runs before the aptfile has installed anything. On the htpc's
# first bootstrap, that ordering meant the setup block below disabled
# systemd-resolved and pointed resolv.conf at a dnsmasq that didn't exist,
# and the box rebooted into a total DNS blackout.
command -v dnsmasq > /dev/null || {
	echo "Installing dnsmasq"

	sudo env DEBIAN_FRONTEND=noninteractive apt install -y dnsmasq
}

echo "Updating dnsmasq blocklist"

$HOME/.dotfiles/ubuntu/bin/dnsmasq-update-blocklist

if [[ ! -f $HOME/.dotfiles/temp/.dnsmasqSetup ]] && ! command -v dnsmasq > /dev/null; then
	# Belt to the install's suspenders: never hand the system resolver to
	# a daemon that isn't there. Setup (and its marker) wait for a run
	# where the install worked, so this self-heals on the next dot-update.
	echo "dnsmasq still missing (apt failed?) - NOT switching the system resolver"
elif [[ ! -f $HOME/.dotfiles/temp/.dnsmasqSetup ]]; then
	echo "Setting up dnsmasq"

	mkdir -p $HOME/.dotfiles/temp

	getent group dnsmasq > /dev/null || sudo groupadd -r dnsmasq

	systemctl list-unit-files resolvconf.service > /dev/null 2>&1 && sudo systemctl disable --now resolvconf

	sudo systemctl stop systemd-resolved
	sudo systemctl disable systemd-resolved

	sudo ln -sf $HOME/.dotfiles/ubuntu/dnsmasq/dnsmasq.conf /etc/dnsmasq.conf
	sudo ln -sf $HOME/.dotfiles/ubuntu/dnsmasq/NetworkManager.conf /etc/NetworkManager/NetworkManager.conf
	sudo ln -sf $HOME/.dotfiles/ubuntu/dnsmasq/dhclient.conf /etc/dhcp/dhclient.conf

	# dnsmasq runs as an unprivileged user and can't traverse into $HOME (mode 750),
	# so these two (read post-privilege-drop) must be real files, not symlinks into $HOME.
	# install -m, not cp: dnsmasq reads both post-privilege-drop, and cp
	# preserves whatever mode the repo copy has (mktemp in the blocklist
	# updater once left it 600 - adblock silently loaded nothing).
	sudo install -m 644 $HOME/.dotfiles/ubuntu/dnsmasq/resolv.personal /etc/resolv.personal
	sudo install -m 644 $HOME/.dotfiles/ubuntu/dnsmasq/hosts.adblock /etc/hosts.adblock

	# Without this, dnsmasq's resolvconf integration adds its own resolv-file
	# alongside ours and refuses to start ("only one resolv.conf file allowed in no-poll mode").
	sudo sed -i 's/^#IGNORE_RESOLVCONF=yes/IGNORE_RESOLVCONF=yes/' /etc/default/dnsmasq

	# NetworkManager.conf sets dns=none, so it no longer manages resolv.conf;
	# dnsmasq (not NM's internal dns=dnsmasq plugin) owns port 53 and adblock/upstream resolution.
	sudo rm -f /etc/resolv.conf
	echo "nameserver 127.0.0.1" | sudo tee /etc/resolv.conf > /dev/null

	sudo systemctl restart NetworkManager

	sudo systemctl enable --now dnsmasq
	sudo systemctl restart dnsmasq

	echo "1" > $HOME/.dotfiles/temp/.dnsmasqSetup
fi
