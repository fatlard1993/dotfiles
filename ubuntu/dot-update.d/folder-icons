#!/bin/zsh

# Yaru-tomorrow: Yaru-yellow-dark with the gold folder icons recolored to
# the shared Tomorrow Night base0A yellow (#f0c674 - the same accent as
# kitty/rofi/polybar/bspwm and the nautilus gtk.css). Yaru ships folders
# as pre-rendered PNGs, so this regenerates a local icon theme that
# overrides only <size>/places and inherits everything else; the recolor
# is a per-channel multiply that maps the folder body color exactly onto
# the target and scales the shading proportionally (hue-rotate turns the
# darker flap garish orange - tested, looks bad).
#
# The body color is sampled from the installed theme at run time (the
# dominant opaque color of folder.png) instead of being hardcoded, so a
# Yaru update that repaints its gold just changes the multipliers here.
# dot-update.d/gtk points icon-theme at the result - alphabetical hook
# order (folder-icons < gtk) means the theme exists before it's selected.

srcTheme=/usr/share/icons/Yaru-yellow-dark
destTheme=$HOME/.local/share/icons/Yaru-tomorrow
hookFile=$HOME/.dotfiles/ubuntu/dot-update.d/folder-icons
target=(240 198 116) # f0c674

# regenerate only when missing, Yaru updated, or this hook changed -
# no reason to repaint ~150 icons on every dot-update
if [[ -d $srcTheme && ( ! $destTheme/index.theme -nt $srcTheme/index.theme || $hookFile -nt $destTheme/index.theme ) ]]; then
	echo "Generating Yaru-tomorrow folder icons"

	# dominant opaque color of the folder body, e.g. "212 156 38"
	body=($(convert $srcTheme/256x256/places/folder.png -depth 8 -format %c histogram:info: \
		| sort -rn | sed -n 's/.*(\([0-9]*\),\([0-9]*\),\([0-9]*\),255).*/\1 \2 \3/p' | head -1))

	mults=($(( ${target[1]}.0 / ${body[1]} )) $(( ${target[2]}.0 / ${body[2]} )) $(( ${target[3]}.0 / ${body[3]} )))

	placesDirs=()

	for srcDir in $srcTheme/*/places(N/); do
		rel=${srcDir#$srcTheme/}
		placesDirs+=($rel)
		mkdir -p $destTheme/$rel

		# everything gold gets tinted; the one non-folder places icon (a
		# landscape thumbnail) is left to the inherited theme untinted
		icons=($srcDir/*.png(N))
		icons=(${icons:#*/preferences-desktop-wallpaper.png})

		mogrify -path $destTheme/$rel \
			-channel R -evaluate Multiply ${mults[1]} \
			-channel G -evaluate Multiply ${mults[2]} \
			-channel B -evaluate Multiply ${mults[3]} \
			+channel $icons
	done

	# minimal index.theme: declare only the dirs shipped here (stanzas
	# copied verbatim from Yaru's) and inherit the rest
	{
		echo "[Icon Theme]"
		echo "Name=Yaru-tomorrow"
		echo "Comment=Yaru-yellow-dark with Tomorrow Night folders (generated by dot-update.d/folder-icons)"
		echo "Inherits=Yaru-yellow-dark"
		echo "Directories=${(j:,:)placesDirs}"

		for dir in $placesDirs; do
			echo "\n[$dir]"
			awk -v sec="[$dir]" '$0 == sec {found=1; next} /^\[/ {found=0} found && NF' $srcTheme/index.theme
		done
	} > $destTheme/index.theme

	# a cache older than the dirs would be ignored; one newer than a
	# stale generation would serve wrong icons - refresh it with the theme
	command -v gtk-update-icon-cache > /dev/null && gtk-update-icon-cache -f -t $destTheme
fi
